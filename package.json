        "axios": "^1.6.2",
        "jwt-decode": "^4.0.0",
        "next": "^16.1.6",
        "next-auth": "^4.24.13",
        "react": "^18.2.0",
        "react-dom": "^18.2.0"
    },
    "devDependencies": {
        "@types/node": "^20.10.5",
        "@types/react": "^18.2.45",
        "@types/react-dom": "^18.2.18",
        "jest": "^29.7.0",
        "jest-environment-jsdom": "^29.7.0",
        "typescript": "^5.3.3"
    }
